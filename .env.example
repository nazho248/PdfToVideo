# Copia este archivo a .env y rellena los valores.
#   cp .env.example .env

# Clave de acceso al microservicio (obligatoria). Pon algo largo y secreto.
PDFVIDEO_API_KEY=cambia-esto-por-una-clave-larga-y-secreta

# Conversiones simultáneas (opcional, default 2)
PDFVIDEO_WORKERS=2

# --- Calidad del video (opcional) ---

# Resolución de render en DPI. Más alto = más resolución/nitidez y archivos más
# pesados. 150 = ligero, 300 = calidad de impresión (default), 600 = muy pesado.
PDFVIDEO_DPI=300

# Compresión H.264 (CRF). MÁS BAJO = MEJOR calidad y más peso.
# 0 = sin pérdida, 18 = casi perfecto (default), 23 = normal, 28 = se nota.
PDFVIDEO_CRF=18

# Segundos que dura cada página en el video (default 2)
PDFVIDEO_SECONDS_PER_PAGE=2

# Ruta del SQLite con el estado de los jobs (opcional, default jobs.db)
# PDFVIDEO_DB=jobs.db

# Host y puerto de escucha (opcional). No cambies el host en producción.
# PDFVIDEO_HOST=127.0.0.1
# PDFVIDEO_PORT=8001
